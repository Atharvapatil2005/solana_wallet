{
  "name": "@atharvapatil2005/sol-price",
  "version": "1.0.4",
  "description": "A lightweight utility for fetching live Solana (SOL) prices, INR conversion, 24h change, and smart fallback caching.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    }
  },

  "repository": {
    "type": "git",
    "url": "https://github.com/Atharvapatil2005/solana_wallet.git"
  },
  "homepage": "https://github.com/Atharvapatil2005/solana_wallet#readme",
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "solana",
    "sol-price",
    "crypto-price",
    "coingecko",
    "price-feed",
    "inr",
    "currency-formatter",
    "web3",
    "defi",
    "npm-package"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "devDependencies": {
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}