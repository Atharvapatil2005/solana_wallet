{
  "name": "@atharvapatil2005/sol-price",
  "version": "1.0.1",
  "description": "Fetch real-time Solana (SOL) price in Indian Rupees (INR) from CoinGecko",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Atharvapatil2005/solana_wallet.git"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "solana",
    "sol",
    "inr",
    "price",
    "crypto",
    "currency"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "devDependencies": {
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}